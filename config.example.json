{
  "models": {
    "default": "qwen_local",
    "planner": "qwen_reason",
    "coder": "qwen_local",
    "brainstorm": "qwen_explore",
    "reasoner": "qwen_reason",
    "tester": "qwen_local"
  },
  "providers": {
    "qwen_local": {
      "kind": "ollama_native",
      "base_url": "http://127.0.0.1:11434",
      "model": "qwen3.6:27b",
      "temperature": 0.1,
      "max_tokens": 4096,
      "num_ctx": 64000,
      "think": false,
      "timeout_seconds": 240
    },
    "qwen_reason": {
      "kind": "ollama_native",
      "base_url": "http://127.0.0.1:11434",
      "model": "qwen3.6:27b",
      "temperature": 0.0,
      "max_tokens": 4096,
      "num_ctx": 64000,
      "think": true,
      "timeout_seconds": 300
    },
    "qwen_explore": {
      "kind": "ollama_native",
      "base_url": "http://127.0.0.1:11434",
      "model": "qwen3.6:27b",
      "temperature": 0.75,
      "max_tokens": 4096,
      "num_ctx": 64000,
      "think": true,
      "timeout_seconds": 300
    },
    "fast_planner": {
      "kind": "openai_compatible",
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key_env": "OLLAMA_API_KEY",
      "model": "qwen3.6:27b",
      "temperature": 0.0,
      "max_tokens": 2048,
      "think": false,
      "disable_thinking_with_assistant_prefill": false,
      "extra_body": {},
      "timeout_seconds": 120
    }
  },
  "mcp_servers": {},
  "workflow": {
    "max_code_test_loops": 3,
    "command_timeout_seconds": 120,
    "command_output_limit": 200000,
    "readme_first": true,
    "project_instruction_files": [],
    "project_context_files": [],
    "project_context_char_limit": 12000,
    "external_context_paths": [],
    "external_context_char_limit": 12000,
    "external_context_item_char_limit": 6000,
    "allowed_file_globs": ["src/**/*.py", "tests/**/*.py", "*.py"],
    "writable_files": [],
    "context_symbols": {},
    "test_commands": ["python3 -m pytest -q"],
    "metric_regex": null,
    "metric_goal": "minimize",
    "baseline_metric": null,
    "require_metric": false,
    "accept_if_improved": false,
    "retry_rejected_candidates": false,
    "reflect_before_retry": false,
    "code_output_format": "json",
    "prompt_cache_friendly_layout": true,
    "current_source_context_before_code": true,
    "current_source_context_char_limit": 12000,
    "log_raw_model_outputs": false,
    "raw_model_output_dir": ".local_micro_agent/raw_model_outputs",
    "candidate_queue": false,
    "candidate_novelty_gate": false,
    "adaptive_search_memory": false,
    "adaptive_search_reject_cooled_axes": false,
    "adaptive_search_force_strategy_axis": false,
    "adaptive_search_strict_axis_pool": false,
    "adaptive_search_axis_pool": [],
    "adaptive_search_axis_keywords": {},
    "adaptive_search_axis_guidance": {},
    "adaptive_search_axis_window": 8,
    "adaptive_search_axis_failure_threshold": 3,
    "adaptive_search_axis_cooldown_loops": 3,
    "adaptive_search_recent_limit": 20,
    "brainstorm_after_rejections": 0,
    "pre_improvement_todo_blocks_brainstorm": true,
    "brainstorm_reject_summary_limit": 8,
    "brainstorm_feedback_notes_limit": 8,
    "brainstorm_new_family_after_all_skipped": 2,
    "brainstorm_forbidden_selection_limit": 24,
    "brainstorm_open_novelty_lanes": [],
    "brainstorm_tactics_path": ".local_micro_agent/brainstorm_tactics.md",
    "todo_plan_path": ".local_micro_agent/todo_plan.json",
    "active_todo_path": ".local_micro_agent/active_todo.json",
    "todo_attempts_path": ".local_micro_agent/todo_attempts.jsonl",
    "failed_tactics_path": ".local_micro_agent/failed_tactics.jsonl",
    "validated_patterns_path": ".local_micro_agent/validated_patterns.jsonl",
    "todo_attempt_budget": 1,
    "todo_ledger_summary_limit": 8,
    "failed_tactic_signature_limit": 16,
    "failed_tactic_family_limit": 24,
    "failed_tactic_similarity_threshold": 0.45,
    "candidate_history_path": null,
    "candidate_history_limit": 20,
    "record_candidate_artifacts": false,
    "candidate_artifact_dir": ".local_micro_agent/candidate_artifacts",
    "candidate_artifact_output_limit": 12000,
    "diagnostic_commands": [],
    "diagnostic_timeout_seconds": 120,
    "diagnostic_output_limit": 12000,
    "observation_backed_todo_continuation": true,
    "todo_observation_chain_attempt_limit": 5,
    "reasoning_lane_enabled": false,
    "reasoning_lane_model_role": "reasoner",
    "reasoning_lane_call_sites": ["plan", "semantic_analysis", "reflect"],
    "reasoning_lane_excluded_roles": ["coder", "brainstorm", "tester"],
    "structural_tactic_lifecycle": true,
    "structural_tactic_soft_failures": 2,
    "structural_state_checkpoint": true,
    "structural_state_path": ".local_micro_agent/structural_state.json",
    "structural_checkpoint_dir": ".local_micro_agent/structural_checkpoints",
    "structural_state_checkpoint_limit": 8,
    "structural_state_context_limit": 3,
    "structural_state_patch_context_limit": 1800,
    "semantic_analysis_after_read": false,
    "semantic_analysis_path": ".local_micro_agent/semantic_analysis.md",
    "semantic_analysis_curated_path": ".local_micro_agent/semantic_analysis.curated.md",
    "semantic_analysis_focus": "",
    "semantic_analysis_model_role": "planner",
    "semantic_analysis_char_limit": 8000,
    "repair_target_not_found": false,
    "repair_source_context_char_limit": 20000,
    "feedback_notes_limit": 12
  }
}
